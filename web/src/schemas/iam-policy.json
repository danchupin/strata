{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://strata.local/schemas/iam-policy.json",
  "title": "IAM Policy Document",
  "type": "object",
  "required": ["Statement"],
  "additionalProperties": false,
  "properties": {
    "Version": {
      "type": "string",
      "enum": ["2008-10-17", "2012-10-17"],
      "description": "Policy language version. AWS canonical: 2012-10-17."
    },
    "Id": {
      "type": "string",
      "description": "Optional policy identifier."
    },
    "Statement": {
      "oneOf": [
        { "$ref": "#/definitions/Statement" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Statement" }
        }
      ]
    }
  },
  "definitions": {
    "StringOrArray": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "Principal": {
      "oneOf": [
        { "type": "string", "enum": ["*"] },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "AWS": { "$ref": "#/definitions/StringOrArray" },
            "Service": { "$ref": "#/definitions/StringOrArray" },
            "Federated": { "$ref": "#/definitions/StringOrArray" },
            "CanonicalUser": { "$ref": "#/definitions/StringOrArray" }
          }
        }
      ]
    },
    "Statement": {
      "type": "object",
      "required": ["Effect"],
      "additionalProperties": false,
      "properties": {
        "Sid": { "type": "string" },
        "Effect": {
          "type": "string",
          "enum": ["Allow", "Deny"]
        },
        "Principal": { "$ref": "#/definitions/Principal" },
        "NotPrincipal": { "$ref": "#/definitions/Principal" },
        "Action": { "$ref": "#/definitions/StringOrArray" },
        "NotAction": { "$ref": "#/definitions/StringOrArray" },
        "Resource": { "$ref": "#/definitions/StringOrArray" },
        "NotResource": { "$ref": "#/definitions/StringOrArray" },
        "Condition": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/definitions/StringOrArray"
            }
          }
        }
      }
    }
  }
}

      "title": "Chunks used",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "description": "strata_rados_cluster_object_count{cluster=\"$cluster\"} — per-cluster object count sampled by the RADOS DataHealth probe (US-001).",
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },

    {
      "id": 13,
      "type": "timeseries",
      "title": "S3 throttling rate by cluster + operation",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 26},
      "description": "strata_data_s3_throttled_total{cluster, operation} (US-001). Bumped on ThrottlingException / SlowDown / RequestLimitExceeded / RequestThrottled / TooManyRequestsException / ProvisionedThroughputExceededException / BandwidthLimitExceeded. retry.GetAttemptResults walks attempt errors so intermediate throttles that ultimately succeed still bump. Sustained throttle rate → request a TPS quota bump from the upstream provider OR back off concurrent writers via STRATA_DATA_S3_CONCURRENCY.",
      "fieldConfig": {
        "defaults": {"unit": "ops"},
        "overrides": []
      },

      "title": "RADOS op latency p50 by pool",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "description": "Median per-pool RADOS op latency (put/get/del) observed via internal/data/rados/observer.go::LogOp. Baseline: p50 < 5 ms on healthy librados. Sustained > 25 ms → check Ceph cluster health (`ceph -s` HEALTH_OK + `ceph osd df` balance).",
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, pool, op) (rate(strata_rados_op_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{pool}} {{op}}",
          "refId": "A"
        }
      ]
    },

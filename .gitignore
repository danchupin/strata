.vscode/

# OS / editor
.DS_Store

# Build caches
/out
/tmp

# pytest
.pytest_cache/
scripts/s3-tests/report/

# python bytecode
__pycache__/
*.pyc

# ralph wrapper bookkeeping (per-checkout state, not source)
scripts/ralph/.last-branch

# bench artifacts (regenerated by `make bench-gc` / `make bench-lifecycle`)
bench-gc-results.jsonl
bench-lifecycle-results.jsonl

# rgw-comparison bench artifacts (US-002+ of ralph/rgw-benchmarks).
# Per-day JSONL + tool benchdata are regenerated by
# `make bench-rgw-comparison` (operator-run, ~120min — NOT CI).
scripts/bench-results/
# RGW bench user creds extracted from `bench-rgw` compose profile via
# `bash scripts/bench-rgw-comparison.sh --extract-rgw-creds` (operator-local).
rgw-creds.env
# warp benchdata files leaked into repo root from direct warp invocations
# (warp adds .json.zst suffix to --benchdata arg). The script writes these
# under a per-run tmpdir, but ad-hoc operator runs may leave stragglers.
warp-*.json.zst
web/node_modules/
web/dist/*
!web/dist/index.html
web/playwright-report/
web/test-results/
web/*.tsbuildinfo

# Hugo docs site build output
docs/site/public/
docs/site/resources/
docs/site/.hugo_build.lock

# Hugo static copy of the OpenAPI contract — regenerated by `make docs-openapi-copy`
# (prerequisite of `docs-build` / `docs-serve`). Source of truth lives in
# internal/adminapi/openapi.yaml.
docs/site/static/openapi.yaml

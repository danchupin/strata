{
  "Role": "arn:aws:iam::123456789012:role/strata-replicator",
  "Rules": [
    {
      "ID": "logs",
      "Priority": 1,
      "Status": "Enabled",
      "Filter": {"Prefix": "logs/"},
      "DeleteMarkerReplication": {"Status": "Disabled"},
      "Destination": {"Bucket": "arn:aws:s3:::__DEST__"}
    }
  ]
}
